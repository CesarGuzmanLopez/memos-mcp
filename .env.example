# ============================================
# Memos Connection (requerido)
# ============================================
# URL de tu instancia de Memos
MEMOS_URL=https://notes.guzman-lopez.com

# NOTA: En modo HTTP, cada cliente envía su propio token vía
# Authorization: Bearer <token>. No se necesita MEMOS_TOKEN aquí.
# MEMOS_TOKEN solo se usa en modo stdio (Claude Desktop/Code).

# ============================================
# HTTP Server (opcional)
# ============================================
# Puerto para el servidor HTTP (default: 3000)
HTTP_PORT=3000

# Host para el servidor HTTP (default: 127.0.0.1)
# Usa 0.0.0.0 para escuchar en todas las interfaces
HTTP_HOST=127.0.0.1

# ============================================
# Seguridad
# ============================================
# Orígenes CORS permitidos (separados por coma)
# Usa * para permitir todos (no recomendado en producción)
CORS_ORIGIN=*

# ============================================
# Logging
# ============================================
# Nivel de logging: debug, info, warn, error
LOG_LEVEL=info